# Audit-form notifications (/api/audit). All optional — without them the API
# logs submissions instead of sending. Set these in Vercel for production.

# Resend API key — enables the email notification to hello@morebookedconsults.com
RESEND_API_KEY=

# Verified Resend sender address (domain must be verified in Resend)
AUDIT_FROM_EMAIL="More Booked Consults <audits@morebookedconsults.com>"

# Optional: POST each submission's JSON to a CRM/Zapier/Make webhook
CRM_WEBHOOK_URL=
